{
  "name": "dantalion-web-demo",
  "version": "0.20.0",
  "description": "The playground web app that calculates the personality from the birthday",
  "keywords": [
    "ba-zi",
    "bazi",
    "birthday",
    "chinese-astrology",
    "console",
    "console-app",
    "four-pillars",
    "library",
    "self-assessment",
    "terminal-app",
    "ziweidoushu",
    "zodiac"
  ],
  "homepage": "https://kurone-kito.github.io/dantalion/",
  "bugs": {
    "url": "https://github.com/kurone-kito/dantalion-web-demo/issues"
  },
  "license": "MIT",
  "author": "kurone-kito <krone@kit.black> (https://kit.black/)",
  "files": [
    ".next",
    "dist"
  ],
  "main": "./dist/index.html",
  "repository": "github:kurone-kito/dantalion-web-demo",
  "scripts": {
    "build": "concurrently -m 1 \"npm:build:storybook\" \"npm:build:next\"",
    "build:next": "next build && next export -o dist",
    "build:re": "concurrently -m 1 \"npm:clean\" \"npm:build\"",
    "build:storybook": "build-storybook --modern -o public/storybook",
    "clean": "rimraf \"*.tgz\" \".eslintcache\" \".next\" \"dist\" \"public/storybook\"",
    "lint": "eslint --cache -f codeframe \"./**/*\"",
    "lint:fix": "npm run -s lint -- --fix",
    "prepare": "husky install",
    "prepack": "npm run -s build:re",
    "serve": "serve dist",
    "start": "concurrently -k \"npm:watch:*\"",
    "test": "npm run -s lint",
    "watch:next": "next dev",
    "watch:storybook": "start-storybook -p 6006 --ci --modern"
  },
  "dependencies": {
    "@emotion/react": "^11.7.1",
    "next": "^12.0.10",
    "react": "^17.0.2",
    "tailwindcss": "^3.0.18"
  },
  "devDependencies": {
    "@commitlint/cli": "^16.1.0",
    "@commitlint/config-conventional": "^16.0.0",
    "@emotion/babel-plugin": "^11.7.2",
    "@emotion/babel-preset-css-prop": "^11.2.0",
    "@storybook/addon-a11y": "^6.4.18",
    "@storybook/addon-docs": "^6.4.18",
    "@storybook/addon-essentials": "^6.4.18",
    "@storybook/addon-interactions": "^6.4.18",
    "@storybook/addons": "^6.4.18",
    "@storybook/builder-webpack5": "^6.4.18",
    "@storybook/core-common": "^6.4.18",
    "@storybook/manager-webpack5": "^6.4.18",
    "@storybook/react": "^6.4.18",
    "@storybook/testing-library": "^0.0.8",
    "@tailwindcss/typography": "^0.5.1",
    "@types/babel__core": "^7.1.18",
    "@types/react": "^17.0.38",
    "@typescript-eslint/eslint-plugin": "^5.10.2",
    "@typescript-eslint/parser": "^5.10.2",
    "autoprefixer": "^10.4.2",
    "browserslist": "^4.19.1",
    "concurrently": "^7.0.0",
    "eslint": "^8.8.0",
    "eslint-config-airbnb-typescript": "^16.1.0",
    "eslint-config-next": "^12.0.10",
    "eslint-config-prettier": "^8.3.0",
    "eslint-formatter-codeframe": "^7.32.1",
    "eslint-import-resolver-typescript": "^2.5.0",
    "eslint-plugin-editorconfig": "^3.2.0",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-jsdoc": "^37.7.1",
    "eslint-plugin-json": "^3.1.0",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-markdown": "^2.2.1",
    "eslint-plugin-next": "^0.0.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.28.0",
    "eslint-plugin-react-hooks": "^4.3.0",
    "eslint-plugin-yaml": "^0.5.0",
    "husky": "^7.0.4",
    "postcss": "^8.4.6",
    "prettier": "^2.5.1",
    "pretty-quick": "^3.1.3",
    "react-dom": "^17.0.2",
    "rimraf": "^3.0.2",
    "serve": "^13.0.2",
    "storybook-addon-turbo-build": "^1.0.1",
    "tailwindcss-neumorphism": "^0.1.0",
    "typescript": "^4.5.5",
    "typescript-eslint-language-service": "^5.0.0",
    "webpack": "^5.68.0"
  },
  "engines": {
    "node": "^17.4.0",
    "npm": "^8.3.1"
  },
  "private": true
}
