{
  "name": "@kurone-kito/dantalion-web-demo-web",
  "version": "0.1.0",
  "private": true,
  "description": "The Solid Start web app for dantalion-web-demo.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "vinxi build",
    "clean": "rimraf -g .output .vinxi coverage node_modules/.cache app.config.timestamp_*.js",
    "dev": "vinxi dev",
    "lint": "biome check app.config.ts package.json scripts src tsconfig.json tsconfig.test.json",
    "lint:fix": "biome check --write app.config.ts package.json scripts src tsconfig.json tsconfig.test.json",
    "preview": "node ./scripts/preview.mjs",
    "start": "node ./scripts/preview.mjs",
    "test": "pnpm run \"/test:.+/\"",
    "test:ts": "tsc -p tsconfig.test.json --noEmit",
    "test:vitest": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@kurone-kito/dantalion-core": "1.0.0-rc.0",
    "@kurone-kito/dantalion-i18n": "1.0.0-rc.0",
    "@solidjs/meta": "0.29.4",
    "@solidjs/router": "0.16.1",
    "@solidjs/start": "1.3.2",
    "isomorphic-dompurify": "3.14.0",
    "marked": "18.0.4",
    "solid-js": "1.9.13"
  },
  "devDependencies": {
    "@solidjs/testing-library": "0.8.10",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.0",
    "daisyui": "5.5.20",
    "jsdom": "29.1.1",
    "mime-db": "1.54.0",
    "tailwindcss": "4.3.0",
    "vinxi": "0.5.11"
  }
}
